# Port on which the Express server will run
PORT=5000

# MongoDB Connection URI
MONGO_URI=mongodb://localhost:27017/academic_ai

# JWT Authentication Config
JWT_SECRET=some_secret_key_here
JWT_EXPIRES_IN=7d

# AI engines and LLM Keys (Optional - Fallbacks to simulation if empty or set to true)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229

# Enable or disable simulated/mock responses when API keys are missing (default: true)
AI_USE_SIMULATION=true
